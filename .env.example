# ── Database (Supabase) ─────────────────────────────────────────────────
# Direct connection works for dev. For prod, switch DATABASE_URL to the pooler (port 6543, ?pgbouncer=true).
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[ref].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[ref].supabase.co:5432/postgres"

# ── Auth.js ─────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ── Google OAuth ────────────────────────────────────────────────────────
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── Web Push (VAPID) ────────────────────────────────────────────────────
# Generate with: node -e "console.log(JSON.stringify(require('web-push').generateVAPIDKeys()))"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# ── Cron secret (for /api/cron/send-reminders) ──────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CRON_SECRET=""
