// Task Manager - Prisma schema
// PostgreSQL + Auth.js v5

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Supabase: pooled url for client, direct url for migrations
}

// ─── Auth.js (NextAuth) standard tables ─────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  projectMemberships  ProjectMember[]
  invitesSent         ProjectInvite[]    @relation("InviterUser")
  tasksCreated        Task[]             @relation("TaskCreator")
  tasksAssigned       Task[]             @relation("TaskAssignee")
  comments            TaskComment[]
  attachmentsUploaded TaskAttachment[]
  tags                Tag[]
  reminders           Reminder[]
  pushSubscriptions   PushSubscription[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Projects & sharing ─────────────────────────────────────────────────────

enum ProjectRole {
  OWNER
  EDITOR
  VIEWER
}

model Project {
  id              String    @id @default(cuid())
  name            String
  color           String? // hex e.g. "#3B82F6"
  icon            String? // emoji or icon name
  isInbox         Boolean   @default(false)
  archivedAt      DateTime?
  position        Float     @default(0)
  parentProjectId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  parent   Project?  @relation("ProjectHierarchy", fields: [parentProjectId], references: [id], onDelete: SetNull)
  children Project[] @relation("ProjectHierarchy")

  members ProjectMember[]
  invites ProjectInvite[]
  tasks   Task[]

  @@index([parentProjectId])
}

model ProjectMember {
  projectId String
  userId    String
  role      ProjectRole @default(EDITOR)
  joinedAt  DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@index([userId])
}

model ProjectInvite {
  id           String      @id @default(cuid())
  projectId    String
  inviterId    String
  inviteeEmail String
  role         ProjectRole @default(EDITOR)
  token        String      @unique
  acceptedAt   DateTime?
  expiresAt    DateTime
  createdAt    DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inviter User    @relation("InviterUser", fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([inviteeEmail])
}

// ─── Tasks ──────────────────────────────────────────────────────────────────

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

model Task {
  id                 String     @id @default(cuid())
  projectId          String
  creatorId          String?
  assigneeId         String?
  parentTaskId       String?
  title              String
  description        String?    @db.Text // markdown
  status             TaskStatus @default(TODO)
  priority           Int        @default(4) // 1 = urgent, 4 = none
  dueAt              DateTime?
  dueHasTime         Boolean    @default(false) // distinguishes "today" vs "today at 15:00"
  completedAt        DateTime?
  recurrenceRule     String? // RFC 5545 RRULE, e.g. "FREQ=WEEKLY;BYDAY=MO"
  recurrenceAnchorAt DateTime? // DTSTART for the RRULE
  position           Float      @default(0)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator    User?   @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  parentTask Task?   @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks   Task[]  @relation("TaskSubtasks")

  comments    TaskComment[]
  attachments TaskAttachment[]
  reminders   Reminder[]
  tags        TaskTag[]

  @@index([projectId, status])
  @@index([assigneeId])
  @@index([dueAt])
  @@index([parentTaskId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String?
  body      String   @db.Text // markdown
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([taskId])
}

// Modeled now, storage layer wired up in Phase 5
model TaskAttachment {
  id         String   @id @default(cuid())
  taskId     String
  uploaderId String?
  filename   String
  mimeType   String
  sizeBytes  Int
  storageKey String // S3 / Supabase Storage object key
  createdAt  DateTime @default(now())

  task     Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader User? @relation(fields: [uploaderId], references: [id], onDelete: SetNull)

  @@index([taskId])
}

// ─── Tags (per-user, personal labels) ───────────────────────────────────────

model Tag {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String?
  createdAt DateTime @default(now())

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks TaskTag[]

  @@unique([userId, name])
}

model TaskTag {
  taskId    String
  tagId     String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([tagId])
}

// ─── Reminders & push delivery ──────────────────────────────────────────────

model Reminder {
  id        String    @id @default(cuid())
  taskId    String
  userId    String
  remindAt  DateTime
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sentAt, remindAt]) // worker scan: WHERE sentAt IS NULL AND remindAt <= now()
  @@index([taskId])
  @@index([userId])
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  endpoint   String   @unique
  p256dh     String // client public key
  auth       String // client auth secret
  userAgent  String?
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
